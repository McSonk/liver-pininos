# This is a template for a .env file configuration.

# Use these variables to create your `.env` file for running this software


PIN_ENV=(local|cloud)

# ram = load all data into RAM (fast but requires enough memory)
# disk = load data from disk on-the-fly (slower but more memory efficient)
# if ram is selected but not enough memory is available, it will automatically fall back to disk with a warning
CACHE_TRAIN_SOURCE=(ram|disk)
CACHE_VAL_SOURCE=(ram|disk)

# example: PIN_ENV=local

# Path to LiTS dataset (.nii.gz files)
LITS_CT_ROOT=/path/to/lits/dataset

# Path to LiTS test dataset (.nii.gz files)
LITS_CT_TEST=/path/to/lits/test/dataset

# Path to save 1) model checkpoints, 2) training logs, 3) TensorBoard logs 4) final results
OUTPUT_DIR=/path/to/save/outputs

# To store/read global and per-case CT statistics (CSV files with mean/std)
STATS_DIR=/path/to/save/stats

# To store/read the split file structure (JSON files with train/val/test splits)
SPLIT_DIR=/path/to/save/splits

# This is optional but recommended
PERSISTENT_DATASET_DIR=/path/where/monai/persistent/dataset/cache/will/be/saved

# (OptionL) Path to pretrained model weights (if using a pretrained model)
PRE_TRAINED_MODEL_PATH=/path/to/pretrained/model/weights.pth

# Logging levels for console and file (choose from DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL_CONSOLE=(DEBUG|INFO|WARNING|ERROR|CRITICAL)
LOG_LEVEL_FILE=(DEBUG|INFO|WARNING|ERROR|CRITICAL)

# (Optional) Email Notifications
ENABLE_EMAIL_NOTIFICATIONS=(true|false)
SMTP_HOST=example.smtp.com
SMTP_PORT=587
EMAIL_SENDER=your.email@gmail.com
EMAIL_PASSWORD=your_16_digit_app_password
EMAIL_RECIPIENT=recipient@email.com

# (Optional) Telegram Notifications
ENABLE_TELEGRAM_NOTIFICATIONS=(true|false)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
